rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "g-02273566@moe-dl.edu.my" && request.auth.token.email_verified == true);
    }

    // Students collection
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Screenings collection
    match /screenings/{screeningId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Phase Tests collection
    match /phase_tests/{testId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Reading Records collection
    match /reading_records/{recordId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
  }
}
